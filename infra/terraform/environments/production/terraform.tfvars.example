# Copy this to terraform.tfvars — all values here are safe to commit.
# Sensitive values (db_password, redis_auth_token) are NOT in this file.
# They are injected by GitHub Actions as TF_VAR_DB_PASSWORD and TF_VAR_REDIS_AUTH_TOKEN secrets.

aws_region   = "ap-south-1"
environment  = "production"
project      = "oae"

# VPC
vpc_cidr = "10.0.0.0/16"

# EKS
eks_cluster_version = "1.31"
node_instance_types = ["t3.medium"]
node_min_size       = 2
node_max_size       = 5
node_desired_size   = 2

# RDS
db_name            = "odi_db"
db_username        = "sudodev"
rds_instance_class = "db.m7g.large"
rds_multi_az       = true

# ElastiCache
redis_node_type    = "cache.t3.small"
redis_num_clusters = 2

# S3
s3_bucket_name = "oae-iitd-files-957905179934"

# Domain
domain = "anyserver.site"

# GitHub OIDC
github_org  = "oae-iitd"
github_repo = "oae_iitd"
